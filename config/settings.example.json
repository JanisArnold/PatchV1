{
  "app": {
    "name": "PATCH",
    "data_dir": "data",
    "benchmark_prompt_path": "data/benchmarks/sample_prompts.json",
    "debug": false,
    "default_profile": "default",
    "runtime_mode": "fast",
    "stream_responses": true,
    "display_enabled": false,
    "camera_enabled": false
  },
  "memory": {
    "recent_turn_limit": 6,
    "max_fact_hits": 5,
    "summary_turn_window": 6,
    "episodic_enabled": true,
    "episodic_backend": "keyword",
    "max_episodic_hits": 3
  },
  "providers": {
    "active": "llama_cpp",
    "llama_cpp": {
      "base_url": "http://127.0.0.1:8080",
      "timeout_seconds": 180,
      "external_server": true
    },
    "ollama": {
      "base_url": "http://127.0.0.1:11434",
      "timeout_seconds": 120
    },
    "cloud": {
      "enabled": false,
      "mode": "heavy_load_only",
      "provider": "",
      "model": ""
    }
  },
  "audio": {
    "input_device": "plughw:3,0",
    "output_device": "plughw:0,0",
    "record_seconds": 30,
    "stt_engine": "whisper_cpp",
    "whisper_cpp_binary": "whisper-cli",
    "whisper_model_path": "stt-models/ggml-small.en-q8_0.bin",
    "vosk_model_path": "stt-models/vosk-model-small-en-us-0.15",
    "piper_voice_dir": "voices",
    "piper_voice_name": "en_US-lessac-medium"
  },
  "model_profiles": {
    "default": {
      "provider": "llama_cpp",
      "model": "gemma-4-e2b-it-qat-q4_0",
      "model_path": "models/gemma-4-e2b-it-qat-q4_0.gguf",
      "temperature": 0.4,
      "top_p": 0.9,
      "num_ctx": 2048,
      "max_tokens": 192,
      "think": false,
      "system_prompt": "You are PATCH, a warm, practical desktop AI companion. Keep spoken replies short: one to three sentences unless asked for more."
    },
    "gemma-4-e2b-qat": {
      "provider": "llama_cpp",
      "model": "gemma-4-e2b-it-qat-q4_0",
      "model_path": "models/gemma-4-e2b-it-qat-q4_0.gguf",
      "temperature": 0.4,
      "top_p": 0.9,
      "num_ctx": 2048,
      "max_tokens": 192,
      "think": false,
      "system_prompt": "You are PATCH, a warm, practical desktop AI companion. Keep spoken replies short: one to three sentences unless asked for more."
    },
    "gemma-4-e4b-qat": {
      "provider": "llama_cpp",
      "model": "gemma-4-e4b-it-qat-q4_0",
      "model_path": "models/gemma-4-e4b-it-qat-q4_0.gguf",
      "temperature": 0.4,
      "top_p": 0.9,
      "num_ctx": 4096,
      "max_tokens": 256,
      "think": false,
      "system_prompt": "You are PATCH, a warm, practical desktop AI companion. Keep spoken replies short: one to three sentences unless asked for more."
    },
    "qwen3.5-4b-q4": {
      "provider": "llama_cpp",
      "model": "qwen3.5-4b-q4",
      "model_path": "models/qwen3.5-4b-q4.gguf",
